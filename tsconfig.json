{
  "compilerOptions": {
    "target": "ES2020",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": false,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./*"
      ]
    },
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "ai-ads-factory-saas/**",
    "ai-poster-studio-pro/**",
    "auto-poster-system-v4/**",
    "BEAUTY_ENGINE_V4_PRESET_LIBRARY_PATCH/**",
    "marketplace_v3_preview_ai_recommend/**",
    "POSTER_QA_AUTOFIX_CTR_VIDEO_PATCH_PACK/**",
    "QA_WINNER_DNA_RECALL_GATE_PATCH/**",
    "SCALE_INTELLIGENCE_ENGINE_PACK/**",
    "SELF_LEARNING_AI_ADS_ENGINE_PACK/**"
  ]
}
